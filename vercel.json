{
	"rewrites": [
		{
			"source": "/docs",
			"has": [
				{
					"type": "host",
					"value": "learnterms.com"
				}
			],
			"destination": "https://learnterms.mintlify.dev/docs"
		},
		{
			"source": "/docs/:match*",
			"has": [
				{
					"type": "host",
					"value": "learnterms.com"
				}
			],
			"destination": "https://learnterms.mintlify.dev/docs/:match*"
		},
		{
			"source": "/docs",
			"has": [
				{
					"type": "host",
					"value": "www.learnterms.com"
				}
			],
			"destination": "https://learnterms.mintlify.dev/docs"
		},
		{
			"source": "/docs/:match*",
			"has": [
				{
					"type": "host",
					"value": "www.learnterms.com"
				}
			],
			"destination": "https://learnterms.mintlify.dev/docs/:match*"
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "app.learnterms.com"
				}
			],
			"destination": "/dashboard/:path*"
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "admin.learnterms.com"
				}
			],
			"destination": "/admin/:path*"
		},
		{
			"source": "/:path*",
			"has": [
				{
					"type": "host",
					"value": "api.learnterms.com"
				}
			],
			"destination": "/api/:path*"
		}
	]
}
